#!/bin/bash
cd /var/lib/local-apt/
mkdir -p dists/stable/main/binary-amd64
dpkg-scanpackages --multiversion pool/ > dists/stable/main/binary-amd64/Packages
gzip -9 --keep --force dists/stable/main/binary-amd64/Packages
apt-ftparchive -c /usr/share/local-apt/conf/apt.conf release dists/stable > dists/stable/Release
