#!/bin/bash
# Update local APT repository with packages from configured sources

set -euo pipefail

CONFIG_FILE="${LOCAL_APT_CONFIG:-/etc/local-apt/packages.conf}"
REPO_DIR="/var/lib/local-apt"
POOL_DIR="$REPO_DIR/pool/main"
LOCKFILE="/run/lock/local-apt.lock"
TEMP_DIR=$(mktemp -d)

# Cleanup temp directory on exit
trap 'rm -rf "$TEMP_DIR"' EXIT

# Logging helper
log_info() {
    logger -t local-apt -p user.info "$1"
    echo "INFO: $1"
}

log_error() {
    logger -t local-apt -p user.err "$1"
    echo "ERROR: $1" >&2
}

log_warn() {
    logger -t local-apt -p user.warning "$1"
    echo "WARNING: $1" >&2
}

# Parse configuration file
# Format: one URL per line, # for comments
parse_packages_config() {
    local config_file="$1"

    while IFS= read -r line || [[ -n "$line" ]]; do
        # Remove leading/trailing whitespace
        line=$(echo "$line" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')

        # Skip empty lines and comments
        [[ -z "$line" || "$line" =~ ^# ]] && continue

        # Output the URL
        echo "$line"
    done < "$config_file"
}

# Download and process a single package
process_package() {
    local url="$1"

    log_info "Processing package from: $url"

    # Download to temp directory with a generated name
    local download_file="$TEMP_DIR/package-$$.deb"

    if ! wget --quiet --content-disposition --timestamping -O "$download_file" "$url" 2>/dev/null; then
        log_warn "Failed to download from $url"
        rm -f "$download_file"
        return 1
    fi

    # Verify it's a valid .deb file
    if ! dpkg-deb -I "$download_file" >/dev/null 2>&1; then
        log_error "Downloaded file from $url is not a valid .deb package"
        rm -f "$download_file"
        return 1
    fi

    # Extract package metadata
    local pkg_name
    local pkg_version
    local pkg_arch
    pkg_name=$(dpkg-deb -f "$download_file" Package 2>/dev/null || echo "")
    pkg_version=$(dpkg-deb -f "$download_file" Version 2>/dev/null || echo "")
    pkg_arch=$(dpkg-deb -f "$download_file" Architecture 2>/dev/null || echo "")

    if [[ -z "$pkg_name" ]]; then
        log_error "Could not extract package name from downloaded file"
        rm -f "$download_file"
        return 1
    fi

    if [[ -z "$pkg_version" ]]; then
        log_error "Could not extract package version from downloaded file"
        rm -f "$download_file"
        return 1
    fi

    # Construct standard Debian package filename
    local std_filename="${pkg_name}_${pkg_version}_${pkg_arch}.deb"

    # Auto-generate target path following Debian pool convention
    # pool/main/<first-letter>/<package-name>/
    local first_letter="${pkg_name:0:1}"
    local target_dir="$POOL_DIR/${first_letter}/${pkg_name}"

    # Create target directory if it doesn't exist
    mkdir -p "$target_dir"

    # Move the .deb file to target directory with standard naming
    if mv "$download_file" "$target_dir/$std_filename"; then
        log_info "Successfully installed $pkg_name to $target_dir/$std_filename"
        return 0
    else
        log_error "Failed to move $pkg_name to $target_dir"
        return 1
    fi
}

# Main execution
main() {
    # Check if config file exists
    if [[ ! -f "$CONFIG_FILE" ]]; then
        log_error "Configuration file not found: $CONFIG_FILE"
        exit 1
    fi

    # Acquire lock to prevent concurrent runs
    exec 200>"$LOCKFILE"
    if ! flock -n 200; then
        log_error "Another instance of update-packages is already running"
        exit 1
    fi

    log_info "Starting package update process"

    # Parse configuration and process each package
    local success_count=0
    local failure_count=0

    while IFS= read -r url; do
        if process_package "$url"; then
            ((success_count++))
        else
            ((failure_count++))
        fi
    done < <(parse_packages_config "$CONFIG_FILE")

    # Update repository metadata
    if [[ $success_count -gt 0 ]]; then
        log_info "Updating repository metadata..."
        if update-local-repo; then
            log_info "Repository update complete: $success_count successful, $failure_count failed"
        else
            log_error "Failed to update repository metadata"
            exit 1
        fi
    else
        if [[ $failure_count -gt 0 ]]; then
            log_warn "No packages were successfully downloaded"
            exit 1
        else
            log_info "No packages configured or all packages disabled"
        fi
    fi

    # Lock will be automatically released when script exits
}

main
