#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_build:
	# No compilation needed for this package

override_dh_auto_test:
	# No tests for this package

override_dh_usrlocal:
	# Allow /usr/local files

override_dh_auto_install:
	dh_auto_install
	# Install scripts from src/bin/
	mkdir -p $(CURDIR)/debian/local-apt/usr/local/bin
	install -m 755 $(CURDIR)/src/bin/update-local-repo $(CURDIR)/debian/local-apt/usr/local/bin/
	install -m 755 $(CURDIR)/src/bin/update-discord-repo $(CURDIR)/debian/local-apt/usr/local/bin/
	# Install sources config
	mkdir -p $(CURDIR)/debian/local-apt/etc/apt/sources.list.d
	install -m 644 $(CURDIR)/src/conf/local.sources $(CURDIR)/debian/local-apt/etc/apt/sources.list.d/
	# Install apt configs
	mkdir -p $(CURDIR)/debian/local-apt/usr/local/mydebs/conf
	install -m 644 $(CURDIR)/src/conf/apt.conf $(CURDIR)/debian/local-apt/usr/local/mydebs/conf/
	install -m 644 $(CURDIR)/src/conf/generate.conf $(CURDIR)/debian/local-apt/usr/local/mydebs/conf/
	install -m 644 $(CURDIR)/src/conf/tree.conf $(CURDIR)/debian/local-apt/usr/local/mydebs/conf/
